# =============================================================================
# CloudFlow 微服务架构 - 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填写实际值
# 使用方式: cp .env.example .env && vi .env
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
# TiDB 密码（必填）
CLOUD_FLOW_DB_PASSWORD=your-strong-db-password-here

# Redis 密码（可选）
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# ClickHouse 配置
# -----------------------------------------------------------------------------
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# -----------------------------------------------------------------------------
# 认证服务配置
# -----------------------------------------------------------------------------
# JWT 私钥（可选，自动生成）
# JWT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# 监控配置
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# 服务端口配置（可选，如需修改默认端口）
# -----------------------------------------------------------------------------
# AUTH_PORT=8006
# CONTROL_PORT=8001
# QUERY_PORT=8007
# TOPOLOGY_PORT=8008
# ALERT_PORT=8009
# TENANT_PORT=8010

# -----------------------------------------------------------------------------
# OIDC 配置（可选，如需启用 OIDC 认证）
# -----------------------------------------------------------------------------
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=http://localhost:8006/api/auth/oidc/callback

# -----------------------------------------------------------------------------
# 邮件通知配置（可选，用于告警通知）
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Slack/DingTalk 通知配置（可选）
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK=
# DINGTALK_WEBHOOK=

# -----------------------------------------------------------------------------
# 时区配置
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
