# =============================================================================
# 云内流量监测系统 - Center 服务环境变量配置模板
# =============================================================================
# 使用方法：复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# ⚠️  生产环境安全警告:
#   1. 请勿使用本文件中的默认值！所有值必须更换为强随机字符串
#   2. 生成强密钥推荐命令: openssl rand -base64 32
#   3. 生产环境请勿将密钥存储在 .env 文件中
#   4. 生产环境推荐使用 Vault / K8s Secrets / AWS Secrets Manager 等密钥管理服务
# =============================================================================

# ----- 数据库配置 -----
# 数据库密码
# 生成方式: openssl rand -base64 16
CLOUD_FLOW_DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# ----- JWT 密钥（必须设置，建议 32+ 字节随机字符串）-----
# 生成方式：openssl rand -base64 32
CLOUD_FLOW_JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET

# ----- 管理员初始密码（必须设置）-----
# 生成方式: openssl rand -base64 12
CLOUD_FLOW_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD

# ----- Redis 密码 -----
# 生成方式: openssl rand -base64 16
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ----- API Key（Edge/Agent 与 Center 通信密钥）-----
# 生成方式: openssl rand -base64 32
CLOUD_FLOW_API_KEY=REPLACE_WITH_API_KEY

# ----- Edge API Key（Center 验证 Edge 身份）-----
# 生成方式: openssl rand -base64 32
CLOUD_FLOW_CENTER_API_KEY=REPLACE_WITH_CENTER_API_KEY

# ----- 日志级别 -----
# 可选值：debug, info, warn, error
CLOUD_FLOW_LOG_LEVEL=info
