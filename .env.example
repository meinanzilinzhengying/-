# CloudFlow 环境变量配置文件
#
# 复制此文件为 .env，然后根据实际环境修改配置
#
# 使用方式：
#   cp .env.example .env
#   docker compose up -d

# 数据库配置
CLOUD_FLOW_DB_PASSWORD=your-db-password-here
MYSQL_ROOT_PASSWORD=${CLOUD_FLOW_DB_PASSWORD}

# ClickHouse 配置
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=ClickHouse2024Secure

# Grafana 配置
GRAFANA_ADMIN_PASSWORD=admin

# 安全配置
TLS_ENABLED=false
TLS_CLIENT_AUTH=false
TLS_INSECURE_SKIP=false
JWT_ENABLED=true
JWT_SECRET=your-secure-jwt-secret-here-change-in-production
WHITELIST_ENABLED=false

# 日志等级
LOG_LEVEL=info
