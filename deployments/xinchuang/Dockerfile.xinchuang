# ==================== EulerOS (华为欧拉) ====================
FROM openeuler/openeuler:22.03-lts AS euler

# 安装运行时依赖
RUN yum install -y \
    ca-certificates \
    tzdata \
    procps-ng \
    curl \
    && yum clean all

# 创建目录
WORKDIR /app
RUN mkdir -p /var/log/cloud-flow /etc/cloud-flow

# 复制二进制
COPY --from=builder /build/cloud-flow-agent /app/
COPY configs/agent.yaml /etc/cloud-flow/agent.yaml

# 设置环境变量
ENV CLOUD_FLOW_CONFIG=/etc/cloud-flow/agent.yaml
ENV TZ=Asia/Shanghai

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD pgrep cloud-flow-agent || exit 1

# 运行
EXPOSE 9090
ENTRYPOINT ["/app/cloud-flow-agent"]
CMD ["-config", "/etc/cloud-flow/agent.yaml"]

# 元数据
LABEL org.opencontainers.image.title="Cloud Flow Agent (EulerOS)"
LABEL org.opencontainers.image.description="Cloud Flow Agent for openEuler/EulerOS"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.vendor="Cloud Flow"
LABEL com.openeuler.version="22.03-lts"

