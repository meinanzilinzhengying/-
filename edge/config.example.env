# ============================================
# Cloud Flow Edge 无状态服务配置示例
# ============================================
# 所有配置通过环境变量读取，支持多实例运行

# --------------------------------------------
# 实例标识配置
# --------------------------------------------
# 实例ID（为空则自动生成）
EDGE_INSTANCE_ID=
# 实例名称
EDGE_INSTANCE_NAME=edge-01
# 区域
EDGE_REGION=cn-north-1
# 可用区
EDGE_ZONE=cn-north-1a

# --------------------------------------------
# 服务配置
# --------------------------------------------
# HTTP服务监听地址
EDGE_SERVER_HOST=0.0.0.0
# HTTP服务端口
EDGE_SERVER_PORT=8080
# 读取超时
EDGE_SERVER_READ_TIMEOUT=30s
# 写入超时
EDGE_SERVER_WRITE_TIMEOUT=30s

# --------------------------------------------
# gRPC配置
# --------------------------------------------
# gRPC监听地址
EDGE_GRPC_HOST=0.0.0.0
# gRPC端口
EDGE_GRPC_PORT=50051
# 最大接收消息大小 (64MB)
EDGE_GRPC_MAX_RECV_MSG_SIZE=67108864
# 最大发送消息大小 (64MB)
EDGE_GRPC_MAX_SEND_MSG_SIZE=67108864
# 保活时间
EDGE_GRPC_KEEPALIVE_TIME=30s
# 保活超时
EDGE_GRPC_KEEPALIVE_TIMEOUT=10s
# 启用TLS
EDGE_GRPC_ENABLE_TLS=false
# TLS证书文件
EDGE_GRPC_TLS_CERT_FILE=
# TLS密钥文件
EDGE_GRPC_TLS_KEY_FILE=
# TLS CA文件
EDGE_GRPC_TLS_CA_FILE=

# --------------------------------------------
# Redis配置（分布式缓存）
# --------------------------------------------
# 启用Redis
EDGE_REDIS_ENABLED=true
# Redis地址
EDGE_REDIS_ADDRESS=redis:6379
# Redis密码
EDGE_REDIS_PASSWORD=
# Redis数据库编号
EDGE_REDIS_DB=0
# 连接池大小
EDGE_REDIS_POOL_SIZE=10
# 最小空闲连接
EDGE_REDIS_MIN_IDLE_CONNS=5
# 最大重试次数
EDGE_REDIS_MAX_RETRIES=3
# 连接超时
EDGE_REDIS_DIAL_TIMEOUT=5s
# 读取超时
EDGE_REDIS_READ_TIMEOUT=3s
# 写入超时
EDGE_REDIS_WRITE_TIMEOUT=3s
# 键前缀
EDGE_REDIS_KEY_PREFIX=edge:

# --------------------------------------------
# Center上游服务配置
# --------------------------------------------
# Center服务地址
EDGE_CENTER_ADDRESS=center:8080
# 认证Token
EDGE_CENTER_AUTH_TOKEN=
# 心跳间隔
EDGE_CENTER_HEARTBEAT_INTERVAL=30s
# 重连间隔
EDGE_CENTER_RECONNECT_INTERVAL=5s

# --------------------------------------------
# Agent连接配置
# --------------------------------------------
# 最大Agent连接数
EDGE_AGENT_MAX_CONNECTIONS=10000
# 会话超时
EDGE_AGENT_SESSION_TIMEOUT=5m
# 启用认证
EDGE_AGENT_AUTH_ENABLED=true
# 认证Token
EDGE_AGENT_AUTH_TOKEN=

# --------------------------------------------
# 负载均衡配置
# --------------------------------------------
# 负载均衡策略: round_robin, least_conn, consistent_hash
EDGE_LB_STRATEGY=least_conn
# 健康检查间隔
EDGE_LB_HEALTH_CHECK_INTERVAL=10s
# 不健康阈值
EDGE_LB_UNHEALTHY_THRESHOLD=3
# 健康阈值
EDGE_LB_HEALTHY_THRESHOLD=2

# --------------------------------------------
# 健康检查配置
# --------------------------------------------
# 启用健康检查
EDGE_HEALTH_ENABLED=true
# HTTP健康检查端口
EDGE_HEALTH_PORT=8081
# gRPC健康检查端口
EDGE_HEALTH_GRPC_PORT=50052

# --------------------------------------------
# 日志配置
# --------------------------------------------
# 日志级别: debug, info, warn, error
EDGE_LOG_LEVEL=info
# 日志格式: json, text
EDGE_LOG_FORMAT=json
# 日志输出: stdout, file
EDGE_LOG_OUTPUT=stdout
