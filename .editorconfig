# EditorConfig 帮助开发者在不同编辑器和IDE之间维护一致的编码风格
# 更多信息: https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Go 文件
[*.go]
indent_size = 4
indent_style = tab

# JavaScript 和 TypeScript
[*.{js,jsx,ts,tsx}]
indent_size = 2

# HTML/CSS/JSON/YAML
[*.{html,css,scss,json,yaml,yml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = 120

# Makefile
[Makefile]
indent_style = tab

# Shell 脚本
[*.{sh,bash}]
indent_size = 4
