# =============================================================================
# 云内流量监测系统 - 环境变量配置
# =============================================================================
# 复制此文件为 .env 并修改对应值
# cp .env.example .env
# =============================================================================
# H4 修复: 所有密码字段必须设置，不允许使用默认值
# =============================================================================

# JWT 密钥（必填，用于签名 JWT Token）
# H4: 必须设置，否则容器无法启动
CLOUD_FLOW_JWT_SECRET=

# Redis 密码（必填）
# H4: 必须设置，否则容器无法启动
REDIS_PASSWORD=

# API Key（必填）
# H4: 必须设置，否则服务无法启动
# N1 修复: 两个 API Key 的用途说明
# CLOUD_FLOW_API_KEY: 用于 Agent 连接 Edge 和 Center 的认证
#   - Center: 强制要求，未设置时启动失败
#   - Edge: 未设置时跳过认证但发出安全警告
#   - Agent: 用于连接 Edge 时认证
CLOUD_FLOW_API_KEY=

# CLOUD_FLOW_CENTER_API_KEY: 用于 Edge 连接 Center 的认证
#   - 如果未设置，Edge 会使用 CLOUD_FLOW_API_KEY
CLOUD_FLOW_CENTER_API_KEY=

# Grafana 管理员密码（必填）
# H4: 必须设置，否则容器无法启动
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Center 管理员密码（必填）
# H4: 必须设置，否则容器无法启动
CLOUD_FLOW_ADMIN_PASSWORD=

# SMTP 配置（告警邮件通知）
SMTP_HOST=
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=

# 告警通知邮箱
ALERT_EMAIL_TO=
