ENV TZ=Asia/Shanghai

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD pgrep cloud-flow-agent || exit 1

# 运行
EXPOSE 9090
ENTRYPOINT ["/app/cloud-flow-agent"]
CMD ["-config", "/etc/cloud-flow/agent.yaml"]

# 元数据
LABEL org.opencontainers.image.title="Cloud Flow Agent (Kunpeng)"
LABEL org.opencontainers.image.description="Cloud Flow Agent for Huawei Kunpeng ARM64"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.vendor="Cloud Flow"
LABEL com.huawei.arch="kunpeng"

