# =============================================================================
# CloudFlow 环境变量配置
# =============================================================================
# 使用方法:
#   cp .env.example .env
#   # 编辑 .env 文件配置你的值
#   docker compose up -d
# =============================================================================

# 数据库密码（必填）
CLOUD_FLOW_DB_PASSWORD=your_secure_password_here

# Grafana 管理员密码
GRAFANA_ADMIN_PASSWORD=admin123

# ClickHouse 配置
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# 外部访问配置（可选）
# 如果需要从外部访问数据库，取消注释以下行
# EXPOSE_TIDB=true
# EXPOSE_CLICKHOUSE=true
# EXPOSE_KAFKA=true
