# Cloud Flow Center 环境变量配置示例
# 复制为 .env 文件并修改相应值

# ==================== 服务标识 ====================
CENTER_ID=center-1
CENTER_MODE=standalone  # standalone 或 cluster

# ==================== HTTP服务 ====================
HTTP_ADDR=:8080
HTTP_PORT=8080
HEALTH_PORT=8081
READ_TIMEOUT=60s
WRITE_TIMEOUT=60s
IDLE_TIMEOUT=120s
MAX_HEADER_BYTES=1048576

# ==================== 日志 ====================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json, text

# ==================== 数据库配置（TiDB/PostgreSQL） ====================
DATABASE_ADDR=localhost:5432
DATABASE_USERNAME=cloudflow
DATABASE_PASSWORD=your_password
DATABASE_NAME=cloudflow

# 连接池
DATABASE_MAX_OPEN_CONNS=100
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFE=30m

# SSL配置
DATABASE_SSL_MODE=disable  # disable, require, verify-ca, verify-full
DATABASE_SSL_CA=
DATABASE_SSL_CERT=
DATABASE_SSL_KEY=
DATABASE_CONN_TIMEOUT=10s

# ==================== Redis配置 ====================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# 连接池
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=10

# 超时
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# 集群模式
REDIS_MODE=single  # single, cluster, sentinel
REDIS_MASTER_NAME=mymaster
REDIS_USERNAME=
