# =============================================================================
# 云内流量监测系统 - Center 服务环境变量配置示例
# =============================================================================
# 使用方法：复制此文件为 .env 并填入实际值
#   cp .env.example .env
# =============================================================================

# ----- 数据库配置 -----
CLOUD_FLOW_DB_PASSWORD=your_strong_db_password_here

# ----- JWT 密钥（必须设置，建议 32+ 字节随机字符串）-----
# 生成方式：openssl rand -base64 32
CLOUD_FLOW_JWT_SECRET=your_jwt_secret_here_change_in_production

# ----- 管理员初始密码（必须设置）-----
CLOUD_FLOW_ADMIN_PASSWORD=your_admin_password_here

# ----- Redis 密码 -----
REDIS_PASSWORD=your_redis_password_here

# ----- API Key（Edge/Agent 与 Center 通信密钥）-----
CLOUD_FLOW_API_KEY=your_api_key_here

# ----- Edge API Key（Center 验证 Edge 身份）-----
CLOUD_FLOW_CENTER_API_KEY=your_center_api_key_here

# ----- 日志级别 -----
# 可选值：debug, info, warn, error
CLOUD_FLOW_LOG_LEVEL=info
