# =============================================================================
# 云内流量监测系统 - 环境变量配置
# =============================================================================
# 复制此文件为 .env 并修改对应值
# cp .env.example .env
# =============================================================================

# JWT 密钥（必填，用于签名 JWT Token）
CLOUD_FLOW_JWT_SECRET=change-me-to-a-random-secret-key

# Redis 密码
REDIS_PASSWORD=change-me-redis-password

# API Key（可选）
CLOUD_FLOW_API_KEY=
CLOUD_FLOW_CENTER_API_KEY=

# Grafana 管理员密码
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
CLOUD_FLOW_ADMIN_PASSWORD=admin

# SMTP 配置（告警邮件通知）
SMTP_HOST=
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=

# 告警通知邮箱
ALERT_EMAIL_TO=
