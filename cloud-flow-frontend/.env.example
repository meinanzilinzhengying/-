# =============================================================================
# 云内流量监测系统 (Cloud Flow) - 前端环境变量配置
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改配置值
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# API 配置
# -----------------------------------------------------------------------------

# 后端 API 基础地址（必填）
# 开发环境示例: http://localhost:8082/api
# 生产环境示例: https://api.cloud-flow.example.com/api
VITE_API_BASE_URL=http://localhost:8082/api

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------

# 应用标题（可选，默认: 云内流量监测系统）
# VITE_APP_TITLE=云内流量监测系统

# 应用端口（可选，默认: 3000，仅开发环境生效）
# VITE_PORT=3000

# 是否开启调试模式（可选，默认: false）
# 开启后会在控制台输出详细的调试信息
# VITE_DEBUG=false

# -----------------------------------------------------------------------------
# 功能开关
# -----------------------------------------------------------------------------

# 是否启用链路追踪功能（可选，默认: true）
# VITE_ENABLE_TRACING=true

# 是否启用性能分析功能（可选，默认: true）
# VITE_ENABLE_PROFILING=true

# 是否启用告警功能（可选，默认: true）
# VITE_ENABLE_ALERTS=true

# 数据刷新间隔（毫秒，可选，默认: 30000）
# VITE_REFRESH_INTERVAL=30000

# -----------------------------------------------------------------------------
# 外部服务配置
# -----------------------------------------------------------------------------

# Grafana 地址（可选，用于嵌入监控面板）
# VITE_GRAFANA_URL=

# Prometheus 地址（可选，用于嵌入指标查询）
# VITE_PROMETHEUS_URL=
