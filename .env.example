# =============================================================================
# CloudFlow 环境变量配置模板
# =============================================================================
# 使用方法:
#   cp .env.example .env
#   # 编辑 .env 文件配置你的值
#   docker compose up -d
#
# ⚠️  生产环境安全警告:
#   1. 请勿使用本文件中的默认值！所有值必须更换为强随机字符串
#   2. 生成强密钥推荐命令: openssl rand -base64 32
#   3. 生产环境请勿将密钥存储在 .env 文件中
#   4. 生产环境推荐使用 Vault / K8s Secrets / AWS Secrets Manager 等密钥管理服务
# =============================================================================

# 数据库密码（必填，生产环境必须设置强密码）
# 生成方式: openssl rand -base64 16
CLOUD_FLOW_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Grafana 管理员密码
# 生成方式: openssl rand -base64 12
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

# ClickHouse 配置
CLICKHOUSE_USER=default
# ClickHouse 密码
# 生成方式: openssl rand -base64 16
CLICKHOUSE_PASSWORD=REPLACE_WITH_CLICKHOUSE_PASSWORD

# JWT 私钥（RSA 密钥对，Base64 编码）
# 生成方式: openssl genrsa -out private.pem 2048 && base64 -w 0 private.pem
JWT_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_RSA_PRIVATE_KEY

# Redis 密码
# 生成方式: openssl rand -base64 16
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# API 密钥（Edge/Agent 与 Center 通信密钥）
# 生成方式: openssl rand -base64 32
CLOUD_FLOW_API_KEY=REPLACE_WITH_API_KEY

# 外部访问配置（可选，生产环境建议禁用）
# EXPOSE_TIDB=false
# EXPOSE_CLICKHOUSE=false
# EXPOSE_KAFKA=false
