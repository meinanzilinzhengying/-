# =============================================================================
# 云内流量监测系统 - 环境变量配置
# =============================================================================
# 复制此文件为 .env 并修改对应值
# cp .env.example .env
# =============================================================================
# H4 修复: 所有密码字段必须设置，不允许使用默认值
# =============================================================================

# JWT 密钥（必填，用于签名 JWT Token）
# H4: 必须设置，否则容器无法启动
CLOUD_FLOW_JWT_SECRET=

# Redis 密码（必填）
# H4: 必须设置，否则容器无法启动
REDIS_PASSWORD=

# API Key（必填）
# H4: 必须设置，否则服务无法启动
CLOUD_FLOW_API_KEY=
CLOUD_FLOW_CENTER_API_KEY=

# Grafana 管理员密码（必填）
# H4: 必须设置，否则容器无法启动
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Center 管理员密码（必填）
# H4: 必须设置，否则容器无法启动
CLOUD_FLOW_ADMIN_PASSWORD=

# SMTP 配置（告警邮件通知）
SMTP_HOST=
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=

# 告警通知邮箱
ALERT_EMAIL_TO=
